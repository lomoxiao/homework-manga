{
  "name": "homework-manga",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @homework-manga/web",
    "build": "tsc --noEmit --pretty false && npm run build --workspace @homework-manga/web",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "contract:check": "node ../scripts/sync-manga-plan-contract.mjs --check"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.15.32",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
