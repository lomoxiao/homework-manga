            "messageForParent",
          ],
          "type": "object",
        },
        "id": {
          "minLength": 1,
          "type": "string",
        },
        "ownerUid": {
          "minLength": 1,
          "type": "string",
        },
        "phase": {
          "enum": [
            "captured",
            "analyzing",
            "awaiting_approval",
            "scripting",
            "ready",
            "failed",
            "deleting",
          ],
          "type": "string",
        },
        "queueKey": {
          "minLength": 1,
          "type": "string",
        },
        "runState": {
          "enum": [
            "queued",
            "running",
            "done",
            "error",
          ],
          "type": "string",
        },
        "sourceImage": {
          "additionalProperties": false,
          "properties": {
            "contentType": {
              "minLength": 1,
              "type": "string",
            },
            "displayUrl": {
              "type": "string",
            },
            "downloadUrl": {
              "minLength": 1,
              "type": "string",
            },
            "fileId": {
              "minLength": 1,
              "type": "string",
            },
            "provider": {
              "const": "google_drive",
              "type": "string",
            },
            "size": {
              "minimum": 0,
              "type": "integer",
            },
            "viewUrl": {
              "minLength": 1,
              "type": "string",
            },
          },
          "required": [
            "provider",
            "fileId",
            "contentType",
            "size",
            "viewUrl",
            "downloadUrl",
          ],
          "type": "object",
        },
        "updatedAt": {
          "minLength": 1,
          "type": "string",
        },
      },
      "required": [
        "id",
        "ownerUid",
        "createdAt",
        "updatedAt",
        "phase",
        "runState",
        "queueKey",
      ],
      "type": "object",
    },
  },
}
`;

