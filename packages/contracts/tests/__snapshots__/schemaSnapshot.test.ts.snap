exports[`contract snapshots > ApprovedProblem v3 1`] = `
{
  "$ref": "#/definitions/ApprovedProblemV3",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ApprovedProblemV3": {
      "additionalProperties": false,
      "properties": {
        "canonicalAnswer": {
          "default": "",
          "maxLength": 500,
          "type": "string",
        },
        "correctAnswer": {
          "maxLength": 500,
          "minLength": 1,
          "type": "string",
        },
        "grade": {
          "anyOf": [
            {
              "maximum": 6,
              "minimum": 1,
              "type": "integer",
            },
            {
              "type": "null",
            },
          ],
          "default": null,
        },
        "mistakeCause": {
          "maxLength": 1000,
          "minLength": 1,
          "type": "string",
        },
        "problemText": {
          "maxLength": 2000,
          "minLength": 1,
          "type": "string",
        },
        "schemaVersion": {
          "const": "3.0",
          "default": "3.0",
          "type": "string",
        },
        "selectedProblemId": {
          "default": "",
          "maxLength": 100,
          "type": "string",
        },
        "studentAnswer": {
          "maxLength": 500,
          "minLength": 1,
          "type": "string",
        },
        "subject": {
          "const": "math",
          "default": "math",
          "type": "string",
        },
      },
      "required": [
        "problemText",
        "studentAnswer",
        "correctAnswer",
        "mistakeCause",
      ],
      "type": "object",
    },
  },
}
`;

