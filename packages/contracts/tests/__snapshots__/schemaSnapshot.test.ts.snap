          "minLength": 1,
          "type": "string",
        },
        "failure": {
          "additionalProperties": false,
          "properties": {
            "code": {
              "enum": [
                "IMAGE_UNREADABLE",
                "AI_OUTPUT_UNUSABLE",
                "MATH_UNVERIFIED",
                "ATTEMPTS_EXHAUSTED",
                "INTERNAL_ERROR",
              ],
              "type": "string",
            },
            "detailJson": {
              "maxLength": 20000,
              "type": "string",
            },
            "messageForParent": {
              "maxLength": 500,
              "minLength": 1,
