                },
                "maxItems": 20,
                "type": "array",
              },
              "id": {
                "maxLength": 100,
                "minLength": 1,
                "type": "string",
              },
              "mistakeCause": {
                "maxLength": 1000,
                "type": "string",
              },
              "problemText": {
                "maxLength": 2000,
                "minLength": 1,
