{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.homework-manga/schemas/homework-draft.schema.json",
  "title": "HomeworkDraftV2", "type": "object", "additionalProperties": false,
  "required": ["schemaVersion","grade","subject","curriculumDomain","topic","problemType","problemText","studentAnswer","correctAnswer","mistakeCause","givens","unknowns","constraints","studentWork","canonicalAnswer","solutionSteps","misconception","verification"],
  "properties": {
    "schemaVersion":{"const":"2.0"}, "grade":{"type":["integer","null"],"minimum":1,"maximum":6}, "subject":{"const":"math"},
    "curriculumDomain":{"enum":["number_calculation","geometry","measurement","change_relationships","data"]},
    "topic":{"type":"string"}, "problemType":{"enum":["calculation","word_problem","construction","multiple_choice","table_graph","explanation"]},
    "problemText":{"type":"string","minLength":1}, "studentAnswer":{"type":"string","minLength":1}, "correctAnswer":{"type":"string","minLength":1}, "mistakeCause":{"type":"string","minLength":1},
    "givens":{"type":"array","items":{"type":"string"}}, "unknowns":{"type":"array","items":{"type":"string"}}, "constraints":{"type":"array","items":{"type":"string"}}, "studentWork":{"type":"array","items":{"type":"string"}},
    "canonicalAnswer":{"type":"string"}, "misconception":{"type":"string"},
    "solutionSteps":{"type":"array","items":{"type":"object","required":["id","explanation","expression","result"],"properties":{"id":{"type":"string"},"explanation":{"type":"string"},"expression":{"type":"string"},"result":{"type":"string"}}}},
    "verification":{"type":"object","required":["method","status","confidence","warnings"],"properties":{"method":{"enum":["rational_arithmetic","ratio_percent","unit_conversion","geometry_formula","statistics","table_consistency","substitution","manual"]},"status":{"enum":["verified","needs_review","unsupported"]},"confidence":{"type":"number","minimum":0,"maximum":1},"warnings":{"type":"array","items":{"type":"string"}}}}
  }
}
