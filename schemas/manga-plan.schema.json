{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.homework-manga/schemas/manga-plan.schema.json",
  "title": "MangaPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "jobId", "title", "problem", "panels"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "jobId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "studentAnswer", "correctAnswer"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "studentAnswer": { "type": "string", "minLength": 1 },
        "correctAnswer": { "type": "string", "minLength": 1 }
      }
    },
    "panels": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["panelNumber", "learningPurpose", "scene", "characters", "background", "dialogue", "narration", "visualAid", "formula", "emphasisWords", "layout", "assetIds"],
        "properties": {
          "panelNumber": { "type": "integer", "minimum": 1, "maximum": 6 },
          "learningPurpose": { "type": "string", "minLength": 1 },
          "scene": { "type": "string", "minLength": 1 },
          "characters": { "type": "array", "items": { "type": "string" } },
          "characterPose": { "type": "object", "additionalProperties": { "type": "string" } },
          "characterExpression": { "type": "object", "additionalProperties": { "type": "string" } },
          "background": { "type": "string" },
          "props": { "type": "array", "items": { "type": "string" } },
          "dialogue": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["speaker", "text", "tone"],
              "properties": {
                "speaker": { "type": "string" },
                "text": { "type": "string" },
                "tone": { "enum": ["normal", "question", "encourage", "discovery"] }
              }
            }
          },
          "narration": { "type": ["string", "null"] },
          "visualAid": {
            "anyOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "total", "groups", "perGroup", "label"],
                "properties": {
                  "type": { "const": "bar_model" },
                  "total": { "type": "number", "exclusiveMinimum": 0 },
                  "groups": { "type": "integer", "minimum": 1 },
                  "perGroup": { "type": "number", "exclusiveMinimum": 0 },
                  "label": { "type": "string" }
                }
              }
            ]
          },
          "formula": { "type": "array", "items": { "type": "string" } },
          "emphasisWords": { "type": "array", "items": { "type": "string" } },
          "layout": {
            "type": "object",
            "additionalProperties": false,
            "required": ["size", "characterSide", "visualAidPosition"],
            "properties": {
              "size": { "enum": ["small", "medium", "large"] },
              "characterSide": { "enum": ["left", "right"] },
              "visualAidPosition": { "enum": ["center", "bottom", "right"] }
            }
          },
          "assetIds": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
